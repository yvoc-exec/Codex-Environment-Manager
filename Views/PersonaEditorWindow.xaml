<Window x:Class="CodexEnvironmentManager.Views.PersonaEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Height="760" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#0d1117" Foreground="#c9d1d9">
    <Window.Resources>
        <DataTemplate x:Key="ChoiceItemTemplate">
            <TextBlock Text="{Binding Label}" ToolTip="{Binding Description}"/>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Profile Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile name" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="Friendly display name for this launch profile."/>
                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Margin="0,4"
                         ToolTip="Friendly display name for this launch profile."/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Icon" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="Small icon shown beside the profile name in the UI."/>
                <ComboBox x:Name="IconBox" Grid.Row="1" Grid.Column="1" Margin="0,4"
                          ToolTip="Small icon shown beside the profile name in the UI."
                          ItemTemplate="{StaticResource ChoiceItemTemplate}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Model" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="Provider is inferred from the selected model. Codex models keep Codex controls; Kimi models disable unsupported Codex-only fields."/>
                <ComboBox x:Name="ModelBox" Grid.Row="2" Grid.Column="1" Margin="0,4"
                          ToolTip="Provider is inferred from the selected model. Codex models keep Codex controls; Kimi models disable unsupported Codex-only fields."
                          ItemTemplate="{StaticResource ChoiceItemTemplate}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Reasoning effort" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="How much reasoning the model should spend before answering or acting."/>
                <ComboBox x:Name="ReasoningBox" Grid.Row="3" Grid.Column="1" Margin="0,4"
                          ToolTip="How much reasoning the model should spend before answering or acting."
                          ItemTemplate="{StaticResource ChoiceItemTemplate}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Sandbox mode" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="Choose how much file access Codex gets inside and outside the workspace."/>
                <ComboBox x:Name="SandboxBox" Grid.Row="4" Grid.Column="1" Margin="0,4"
                          ToolTip="Choose how much file access Codex gets inside and outside the workspace."
                          ItemTemplate="{StaticResource ChoiceItemTemplate}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Approval policy" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="How often Codex should ask before risky actions."/>
                <ComboBox x:Name="ApprovalBox" Grid.Row="5" Grid.Column="1" Margin="0,4"
                          ToolTip="How often Codex should ask before risky actions."
                          ItemTemplate="{StaticResource ChoiceItemTemplate}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Approvals reviewer" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="Choose who reviews approval requests for this profile."/>
                <ComboBox x:Name="ApprovalsReviewerBox" Grid.Row="6" Grid.Column="1" Margin="0,4"
                          ToolTip="Choose who reviews approval requests for this profile."
                          ItemTemplate="{StaticResource ChoiceItemTemplate}"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Template tools" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="Open templates, open this profile's linked template, or request Codex-level AGENTS.md refresh."/>
                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4">
                    <Button Content="📋 Templates" Width="120" Margin="0,0,8,0"
                            x:Name="OpenTemplatesButton" Click="OpenTemplatesFolder_Click"
                            ToolTip="Open the role templates/personas folder."/>
                    <Button Content="📝 Linked" Width="110" Margin="0,0,8,0"
                            x:Name="OpenLinkedTemplateButton" Click="OpenLinkedTemplate_Click"
                            ToolTip="Open or create this profile's linked role template."/>
                    <Button Content="↻ Instructions" Width="110"
                            x:Name="InstructionsRefreshButton" Click="RequestInstructionsRefresh_Click"
                            ToolTip="Request regeneration of config.toml profile references, profile instruction files, and compact AGENTS.md after saving this profile."/>
                </StackPanel>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Role template" Margin="0,6" VerticalAlignment="Center"
                           ToolTip="Markdown template that defines the role behavior for this profile. The list is loaded from the user templates/personas folder."/>
                <Grid Grid.Row="8" Grid.Column="1" Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="TemplateBox" Grid.Column="0" Margin="0,0,8,0"
                              ToolTip="Markdown template that defines the role behavior for this profile. The list is loaded from the user templates/personas folder."
                              ItemTemplate="{StaticResource ChoiceItemTemplate}"/>
                    <Button x:Name="RefreshTemplatesButton" Grid.Column="1" Width="90" Content="Refresh"
                            Click="RefreshTemplates_Click"
                            ToolTip="Refresh the role template list from the user templates/personas folder."/>
                </Grid>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Kimi options" Margin="0,6" VerticalAlignment="Top"
                           ToolTip="Safe optional Kimi CLI controls exposed by the profile editor."/>
                <Border x:Name="KimiOptionsBorder" Grid.Row="10" Grid.Column="1" Margin="0,4" Padding="8" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="KimiMigrationWarningBorder" Grid.Row="0" Grid.ColumnSpan="4" Margin="0,0,0,8" Padding="8"
                                BorderBrush="#d29922" BorderThickness="1" CornerRadius="6" Background="#1c1610" Visibility="Collapsed">
                            <TextBlock x:Name="KimiMigrationWarningText" TextWrapping="Wrap" Foreground="#f2cc60"/>
                        </Border>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Thinking mode" Margin="0,6" VerticalAlignment="Center"
                                   ToolTip="Choose whether Kimi should think by default for this profile."/>
                        <ComboBox x:Name="ThinkingModeBox" Grid.Row="1" Grid.Column="1" Margin="0,4,0,4"
                                  ToolTip="Choose whether Kimi should think by default for this profile."
                                  ItemTemplate="{StaticResource ChoiceItemTemplate}"/>
                        <CheckBox x:Name="PlanModeCheckBox" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="12,4,0,4"
                                  Content="Start in plan mode"
                                  ToolTip="Start Kimi in plan mode for this profile."/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Skills directories" Margin="0,6" VerticalAlignment="Top"
                                   ToolTip="One or more directories of reusable Kimi skills."/>
                        <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,4,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="KimiSkillsDirsList" Grid.Row="0" Grid.ColumnSpan="3" Height="95"
                                     ToolTip="Current Kimi skills directories for this profile."/>
                            <Button x:Name="AddKimiSkillsDirButton" Grid.Row="1" Grid.Column="1" Width="90" Margin="0,8,8,0" Content="Add folder"
                                    Click="AddKimiSkillsDir_Click" ToolTip="Add a Kimi skills directory."/>
                            <Button x:Name="RemoveKimiSkillsDirButton" Grid.Row="1" Grid.Column="2" Width="100" Margin="0,8,0,0" Content="Remove"
                                    Click="RemoveKimiSkillsDir_Click" ToolTip="Remove the selected Kimi skills directory."/>
                        </Grid>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="MCP config file" Margin="0,6" VerticalAlignment="Center"
                                   ToolTip="Optional Kimi MCP configuration file."/>
                        <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="KimiMcpConfigBox" Grid.Column="0" Margin="0,0,8,0"
                                     ToolTip="Optional Kimi MCP configuration file path."/>
                            <Button x:Name="BrowseKimiMcpConfigButton" Grid.Column="1" Width="90" Content="Browse"
                                    Click="BrowseKimiMcpConfig_Click" ToolTip="Select a Kimi MCP config file."/>
                        </Grid>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Additional dirs" Margin="0,6" VerticalAlignment="Top"
                                   ToolTip="Optional additional workspace directories available to Kimi."/>
                        <Grid Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,4,0,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ListBox x:Name="KimiAdditionalDirsList" Grid.Row="0" Grid.ColumnSpan="3" Height="95"
                                     ToolTip="Current additional workspace directories for this profile."/>
                            <Button x:Name="AddKimiAdditionalDirButton" Grid.Row="1" Grid.Column="1" Width="90" Margin="0,8,8,0" Content="Add folder"
                                    Click="AddKimiAdditionalDir_Click" ToolTip="Add an additional workspace directory."/>
                            <Button x:Name="RemoveKimiAdditionalDirButton" Grid.Row="1" Grid.Column="2" Width="100" Margin="0,8,0,0" Content="Remove"
                                    Click="RemoveKimiAdditionalDir_Click" ToolTip="Remove the selected additional workspace directory."/>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Extra CLI args" Margin="0,6" VerticalAlignment="Top"
                           ToolTip="Additional Codex CLI arguments. Use only known valid Codex flags."/>
                <Border x:Name="CliArgsBorder" Grid.Row="12" Grid.Column="1" Margin="0,4" Padding="8" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="CliArgPresetBox" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"
                                  ToolTip="Choose a supported extra CLI argument preset."
                                  ItemTemplate="{StaticResource ChoiceItemTemplate}"/>
                        <Button x:Name="AddCliArgButton" Grid.Row="0" Grid.Column="1" Width="80" Margin="0,0,8,8" Content="Add"
                                Click="AddCliArg_Click" ToolTip="Add the selected CLI argument preset to this profile."/>
                        <Button x:Name="RemoveCliArgButton" Grid.Row="0" Grid.Column="2" Width="80" Margin="0,0,0,8" Content="Remove"
                                Click="RemoveCliArg_Click" ToolTip="Remove the selected CLI argument from this profile."/>

                        <ListBox x:Name="CliArgsList" Grid.Row="1" Grid.ColumnSpan="3" Height="100"
                                 ToolTip="Current extra CLI arguments for this profile."/>

                        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Margin="0,8,0,0" Foreground="#8b949e" TextWrapping="Wrap"
                                   Text="Only curated, non-profile-controlled arguments are exposed here so launches stay valid and predictable."/>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="13" Grid.Column="0" Text="Env vars" Margin="0,6" VerticalAlignment="Top"
                           ToolTip="Environment variables injected into launched Codex sessions for this profile."/>
                <Border x:Name="EnvVarsBorder" Grid.Row="14" Grid.Column="1" Margin="0,4" Padding="8" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="EnvVarPresetBox" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"
                                  ToolTip="Choose a supported environment-variable preset."
                                  ItemTemplate="{StaticResource ChoiceItemTemplate}"/>
                        <Button x:Name="AddEnvVarButton" Grid.Row="0" Grid.Column="1" Width="80" Margin="0,0,8,8" Content="Add"
                                Click="AddEnvVar_Click" ToolTip="Add the selected environment-variable preset to this profile."/>
                        <Button x:Name="RemoveEnvVarButton" Grid.Row="0" Grid.Column="2" Width="80" Margin="0,0,0,8" Content="Remove"
                                Click="RemoveEnvVar_Click" ToolTip="Remove the selected environment-variable preset from this profile."/>

                        <ListBox x:Name="EnvVarsList" Grid.Row="1" Grid.ColumnSpan="3" Height="110"
                                 ToolTip="Current environment variables for this profile."/>

                        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Margin="0,8,0,0" Foreground="#8b949e" TextWrapping="Wrap"
                                   Text="Environment variables are restricted to known-good presets so users only select valid values."/>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="15" Grid.Column="1" Margin="0,10,0,0" Foreground="#8b949e" TextWrapping="Wrap"
                           Text="Tip: Hover labels or controls for a short explanation of what each setting does."/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Width="90" Margin="0,0,8,0" Click="Save_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="90" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
