<Window x:Class="CodexEnvironmentManager.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="640" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0d1117" Foreground="#c9d1d9">
    <Window.Resources>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="⚙️ Settings" FontSize="18" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Codex Desktop" VerticalAlignment="Center" Grid.Column="0" ToolTip="Optional. Leave blank to use codex app fallback when Codex CLI is installed."/>
            <TextBox x:Name="DesktopPathBox" Grid.Column="1" IsReadOnly="True"/>
            <Button Content="Browse..." Grid.Column="2" Click="BrowseDesktop_Click" Width="80" ToolTip="Optional. Store-installed Codex can be launched through codex app without selecting an exe."/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Kimi CLI" VerticalAlignment="Center" Grid.Column="0" ToolTip="Optional. Leave blank to auto-detect kimi on PATH."/>
            <TextBox x:Name="KimiPathBox" Grid.Column="1" IsReadOnly="True"/>
            <Button Content="Browse..." Grid.Column="2" Click="BrowseKimi_Click" Width="80" ToolTip="Optional. Select the Kimi CLI executable or command shim."/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Log file" VerticalAlignment="Center" Grid.Column="0"/>
            <TextBox x:Name="LogPathBox" Grid.Column="1" IsReadOnly="True" Foreground="#8b949e"/>
        </Grid>

        <CheckBox x:Name="TrayCheck" Content="Minimize to system tray" Grid.Row="4" Margin="0,8"/>
        <CheckBox x:Name="GitGuardCheck" Content="Enable Git Guard (warn on dirty repos)" Grid.Row="5" Margin="0,4" IsChecked="True"/>
        <CheckBox x:Name="WindowsTerminalCheck" Content="Prefer Windows Terminal for CLI tabs (best-effort PID tracking)" Grid.Row="6" Margin="0,4"/>

        <Grid Grid.Row="7" Margin="0,8,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Windows sandbox" VerticalAlignment="Center" Grid.Column="0"
                       ToolTip="Written to each managed account config.toml as [windows] sandbox."/>
            <ComboBox x:Name="WindowsSandboxCombo" Grid.Column="1" SelectedIndex="0">
                <ComboBoxItem Content="elevated"/>
                <ComboBoxItem Content="unelevated"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="TrustWorkspaceCheck" Grid.Row="8" Margin="0,4"
                  Content="Automatically trust selected workspace on launch"/>

        <TextBlock Grid.Row="9" Margin="0,10,0,4" Foreground="#8b949e" TextWrapping="Wrap"
                   Text="CEM roles are stored in Codex-level AGENTS.md and selected by the active Codex profile. Kimi settings only point CEM at the CLI and do not manage Kimi auth or config files."/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
            <Button Content="↻ Refresh all account configs" Width="190" Click="RefreshAccountConfigs_Click"
                    ToolTip="Adds missing [windows] sandbox config to all managed accounts while preserving existing elevated/unelevated choices."/>
        </StackPanel>

        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12">
            <Button Content="Save" Width="80" Click="Save_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="12" Text="" Foreground="#f85149" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
