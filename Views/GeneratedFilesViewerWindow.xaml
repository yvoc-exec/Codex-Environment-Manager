<Window x:Class="CodexEnvironmentManager.Views.GeneratedFilesViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generated Files Viewer" Height="720" Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117" Foreground="#c9d1d9">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Generated Files Viewer" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBlock x:Name="ContextText" Grid.Row="1" Foreground="#8b949e" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="File" VerticalAlignment="Center" Foreground="#8b949e"/>
            <ComboBox x:Name="FileCombo" Grid.Column="1" Margin="8,0" SelectionChanged="FileCombo_SelectionChanged"
                      ToolTip="Choose which generated file to view."/>
            <Button Grid.Column="2" Content="Refresh" Width="90" Click="Refresh_Click"
                    ToolTip="Reload the selected file from disk."/>
        </Grid>

        <TextBox x:Name="ContentBox" Grid.Row="3" IsReadOnly="True"
                 AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="#010409"
                 Foreground="#c9d1d9"
                 BorderBrush="#30363d"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Copy Path" Width="90" Margin="0,0,8,0" Click="CopyPath_Click"
                    ToolTip="Copy the selected file path."/>
            <Button Content="Copy Content" Width="110" Margin="0,0,8,0" Click="CopyContent_Click"
                    ToolTip="Copy the read-only file content."/>
            <Button Content="Close" Width="90" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
