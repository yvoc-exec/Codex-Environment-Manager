<Window x:Class="CodexEnvironmentManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Codex Environment Manager" Height="720" Width="1150"
        Background="#0d1117" Foreground="#c9d1d9"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        WindowStyle="None" ResizeMode="CanResize" MinHeight="620" MinWidth="980"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#da3633"/>
            <Setter Property="BorderBrush" Value="#f85149"/>
        </Style>
        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#0b0f14" MouseDown="TitleBar_MouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image Source="pack://application:,,,/Assets/AppIcon.ico" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBlock Text="Codex Environment Manager" Foreground="#c9d1d9" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="Account / profile / workspace launcher" Foreground="#6e7681" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="—" Width="44" Height="30" Padding="0" Margin="0" Click="Minimize_Click" ToolTip="Minimize"/>
                <Button Content="□" Width="44" Height="30" Padding="0" Margin="0" Click="MaximizeRestore_Click" ToolTip="Maximize / Restore"/>
                <Button Content="✕" Width="44" Height="30" Padding="0" Margin="0" Background="#3d1517" BorderBrush="#5f2124" Click="CloseWindow_Click" ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <TextBlock Text="ACTIVE ACCOUNT" FontWeight="Bold" Foreground="#8b949e" Margin="4,0,0,4"/>
                <Border Background="#21262d">
                    <TextBlock x:Name="ActiveAccountText" Text="(none)" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </Border>

                <TextBlock Text="ACCOUNTS" FontWeight="Bold" Foreground="#8b949e" Margin="4,12,0,4"/>
                <Border>
                    <StackPanel>
                        <ListBox x:Name="AccountList" Height="130" SelectionChanged="AccountList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Display}" VerticalAlignment="Center"/>
                                        <TextBlock Text="  ●" Foreground="#3fb950" VerticalAlignment="Center" Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Add Account" Click="AddAccount_Click" ToolTip="Add a new account"/>
                            <Button Content="Edit" Click="EditAccount_Click" ToolTip="Rename selected account"/>
                            <Button Content="Delete" Click="DeleteAccount_Click" ToolTip="Delete selected account"/>
                            <Button x:Name="KimiSetupButton" Content="Kimi Setup" Click="KimiSetup_Click" ToolTip="Open Kimi login/setup for the selected Kimi account" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="CEM PROFILES" FontWeight="Bold" Foreground="#8b949e" Margin="4,12,0,4"/>
                <Border>
                    <StackPanel>
                        <ListBox x:Name="PersonaList" Height="110" SelectionChanged="PersonaList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="+" Click="AddPersona_Click" ToolTip="Add CEM profile"/>
                            <Button Content="Edit" Click="EditPersona_Click" ToolTip="Edit selected CEM profile"/>
                            <Button Content="Delete" Click="DeletePersona_Click" ToolTip="Delete selected CEM profile"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <TextBlock Text="WORKSPACES" FontWeight="Bold" Foreground="#8b949e" Margin="4,12,0,4"/>
                <Border>
                    <StackPanel>
                        <ListBox x:Name="WorkspaceList" Height="130" SelectionChanged="WorkspaceList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Path}" Foreground="#8b949e" FontSize="10" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="+" Click="AddWorkspace_Click" ToolTip="Add workspace"/>
                            <Button Content="Open Folder" Click="OpenFolder_Click" ToolTip="Open workspace folder in Explorer"/>
                            <Button Content="Edit" Click="EditWorkspace_Click" ToolTip="Rename workspace"/>
                            <Button Content="Delete" Click="DeleteWorkspace_Click" ToolTip="Delete selected workspace"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button Content="Settings" Margin="0,12,0,0" Click="Settings_Click"/>
                <Button Content="Exit" Style="{StaticResource DangerButton}" Click="Exit_Click"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Active Sessions -->
            <Border Grid.Row="0">
                <DockPanel>
                    <TextBlock Text="ACTIVE SESSIONS" FontWeight="Bold" Foreground="#8b949e" DockPanel.Dock="Top" Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="SessionItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#21262d" Margin="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding TypeIcon}" Width="64" Margin="4,0" VerticalAlignment="Center" TextAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="#8b949e" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding StartTime, StringFormat='{}{0:HH:mm:ss}'}" Foreground="#8b949e" Margin="8,0" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Content="Kill" Tag="{Binding Id}" Click="KillSession_Click" Margin="2"/>
                                            <Button Grid.Column="3" Content="Snapshot" Tag="{Binding Id}" Click="SnapshotSession_Click" Margin="2" ToolTip="Export conversation snapshot" IsEnabled="{Binding CanSnapshot}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Launch Panel -->
            <Border Grid.Row="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="LAUNCH" FontWeight="Bold" Foreground="#8b949e" Grid.Row="0" Margin="0,0,0,8"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="Account" Foreground="#8b949e" Margin="0,0,0,2"/>
                            <ComboBox x:Name="AccountCombo" Foreground="{StaticResource TextBrush}" SelectionChanged="AccountCombo_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" Foreground="{StaticResource TextBrush}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="Profile" Foreground="#8b949e" Margin="0,0,0,2"/>
                            <ComboBox x:Name="PersonaCombo" Foreground="{StaticResource TextBrush}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" Foreground="{StaticResource TextBrush}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="4">
                            <TextBlock Text="Workspace" Foreground="#8b949e" Margin="0,0,0,2"/>
                            <ComboBox x:Name="WorkspaceCombo" Foreground="{StaticResource TextBrush}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                        <Button Content="Launch Desktop" Width="160" Height="36" Click="LaunchDesktop_Click" ToolTip="Single Desktop instance (switches junction)"/>
                        <Button Content="Launch CLI Companion" Width="180" Height="36" Click="LaunchCli_Click" ToolTip="Parallel CLI session in Windows Terminal"/>
                        <Button Content="View Files" Width="110" Height="36" Click="ViewGeneratedFiles_Click" ToolTip="Read-only view of generated config.toml, AGENTS.md, and profile instructions"/>
                        <Button Content="Resume Last" Width="130" Height="36" Click="ResumeLast_Click" ToolTip="Launch with this workspace's last-used account + profile" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusText" Grid.Row="3" Text="Ready" Foreground="#8b949e" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>
